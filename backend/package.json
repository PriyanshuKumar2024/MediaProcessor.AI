{
  "name": "media-processing-backend",
  "version": "1.0.0",
  "description": "API and Worker service for AI-Powered Media Processing Platform",
  "main": "dist/api.js",
  "scripts": {
    "build": "prisma generate && tsc",
    "start:api": "node dist/api.js",
    "start:worker": "node dist/worker.js",
    "db:push": "prisma db push",
    "dev:api": "tsx watch src/api.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "@prisma/client": "^5.12.1",
    "axios": "^1.6.8",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.7.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.35.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.7",
    "@types/supertest": "^7.2.0",
    "prisma": "^5.12.1",
    "supertest": "^7.2.2",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
